# ---------------------------------------------------------------------------
# Variables d'environnement — Annales BEPC & BAC
# Copier ce fichier en `.env` puis renseigner les valeurs.
# ---------------------------------------------------------------------------

# Pilote de base de données :
#   - "pglite"   : base embarquée locale (sans serveur) — idéal pour démarrer.
#   - "postgres" : vrai PostgreSQL (production / docker-compose) via DATABASE_URL.
DB_DRIVER="postgres"
PGLITE_PATH="./.pglite"

# Base de données PostgreSQL (métadonnées du catalogue, driver "postgres").
# Valeur par défaut compatible avec le docker-compose fourni.
DATABASE_URL="postgresql://annales:annales@localhost:5432/annales"

# URL publique canonique du site (SEO, sitemap, Open Graph, partage).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Secret de signature des sessions Auth.js. Générer : openssl rand -base64 32
AUTH_SECRET=""

# Stockage des fichiers PDF :
#   - "local"      : disque (dossier public/uploads) — idéal en développement.
#   - "cloudinary" : Cloudinary (production) — renseigner les clés ci-dessous.
STORAGE_DRIVER="local"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
